generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  ARCHIVED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AuditEntity {
  PROJECT
  TASK
  TIME_ENTRY
  AUTH_SESSION
}

enum AuditAction {
  CREATE
  UPDATE
  SOFT_DELETE
  RESTORE
}

model Workspace {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  ownerId     String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  owner       User          @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  users       User[]        @relation("WorkspaceMembership")
  projects    Project[]
  tasks       Task[]
  tags        Tag[]
  timeEntries TimeEntry[]
  settings    UserSetting[]
  auditLogs   AuditLog[]
}

model User {
  id             String        @id @default(cuid())
  name           String?
  email          String        @unique
  passwordHash   String
  emailVerified  DateTime?
  image          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  workspaceId    String?
  workspace      Workspace?    @relation("WorkspaceMembership", fields: [workspaceId], references: [id], onDelete: SetNull)
  ownedWorkspace Workspace?    @relation("WorkspaceOwner")
  projects       Project[]     @relation("ProjectOwner")
  tasks          Task[]        @relation("TaskOwner")
  timeEntries    TimeEntry[]
  settings       UserSetting?
  accounts       Account[]
  sessions       Session[]
  auditLogs      AuditLog[]
}

model UserSetting {
  id           String    @id @default(cuid())
  userId       String    @unique
  workspaceId  String
  timezone     String    @default("Europe/Madrid")
  dayStartHour Int       @default(8)
  weekStartsOn Int       @default(1)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Project {
  id          String        @id @default(cuid())
  workspaceId String
  ownerId     String
  name        String
  description String?
  color       String        @default("#0F766E")
  icon        String        @default("folder-kanban")
  status      ProjectStatus @default(ACTIVE)
  archivedAt  DateTime?
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner       User          @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  tasks       Task[]
  timeEntries TimeEntry[]

  @@index([workspaceId, status, deletedAt])
  @@index([workspaceId, deletedAt, updatedAt])
}

model Task {
  id            String       @id @default(cuid())
  workspaceId   String
  projectId     String
  ownerId       String
  name          String
  description   String?
  status        TaskStatus   @default(TODO)
  priority      TaskPriority @default(MEDIUM)
  archivedAt    DateTime?
  deletedAt     DateTime?
  estimatedMins Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner         User         @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  taskTags      TaskTag[]
  timeEntries   TimeEntry[]

  @@index([workspaceId, projectId, status, deletedAt])
  @@index([workspaceId, deletedAt, updatedAt])
}

model Tag {
  id          String         @id @default(cuid())
  workspaceId String
  name        String
  color       String         @default("#F59E0B")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  taskTags    TaskTag[]
  entryTags   TimeEntryTag[]

  @@unique([workspaceId, name])
}

model TaskTag {
  taskId String
  tagId  String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model TimeEntry {
  id                  String         @id @default(cuid())
  workspaceId         String
  userId              String
  projectId           String
  taskId              String?
  startedAt           DateTime
  endedAt             DateTime?
  durationSec         Int            @default(0)
  note                String?
  isRunning           Boolean        @default(true)
  pausedAt            DateTime?
  accumulatedPauseSec Int            @default(0)
  deletedAt           DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  workspace           Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project             Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task                Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  entryTags           TimeEntryTag[]

  @@index([userId, isRunning])
  @@index([workspaceId, startedAt])
  @@index([workspaceId, userId, deletedAt, startedAt])
  @@index([workspaceId, projectId, deletedAt])
}

model TimeEntryTag {
  timeEntryId String
  tagId       String
  timeEntry   TimeEntry @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([timeEntryId, tagId])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  deletedAt    DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String      @id @default(cuid())
  workspaceId String
  userId      String?
  entity      AuditEntity
  entityId    String
  action      AuditAction
  before      Json?
  after       Json?
  context     Json?
  createdAt   DateTime    @default(now())
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([entity, entityId, createdAt])
  @@index([userId, createdAt])
}

model RateLimitBucket {
  key         String   @id
  count       Int
  resetAt     DateTime
  blockedUntil DateTime?
  updatedAt   DateTime @updatedAt

  @@index([resetAt])
  @@index([blockedUntil])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
